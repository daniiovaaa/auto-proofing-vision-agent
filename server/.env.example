# Your Google Gemini API key. Required.
GEMINI_API_KEY=your-gemini-key-here

# Port the backend listens on. Optional, defaults to 3001.
PORT=3001

# Origin allowed to call this API (the Vite dev server). Optional.
CLIENT_ORIGIN=http://localhost:5173

# Vision-capable model to use. Optional, defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash